APP_NAME="RouteDNS Admin Panel"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost:8000

# Database Configuration
DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=routedns_admin
DB_USERNAME=root
DB_PASSWORD=

# Mail Configuration
MAIL_MAILER=smtp
MAIL_HOST=smtp.mailtrap.io
MAIL_PORT=465
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_ENCRYPTION=ssl
MAIL_FROM_ADDRESS=noreply@routedns.io
MAIL_FROM_NAME="${APP_NAME}"

# RouteDNS API Configuration
ROUTEDNS_API_URL=https://api.routedns.io
ROUTEDNS_API_KEY=
ROUTEDNS_VALIDATE_ENDPOINT=/dns/validate.php

# Payment Gateway (Stripe)
STRIPE_PUBLIC_KEY=
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# Session Configuration
SESSION_DRIVER=file
SESSION_LIFETIME=120

# Cache Configuration
CACHE_DRIVER=file
CACHE_STORE=file

# Queue Configuration
QUEUE_CONNECTION=sync

# Redis Configuration (Optional)
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

# Security
JWT_SECRET=
HASH_ALGORITHM=bcrypt

# File Upload
FILESYSTEM_DISK=local
MAX_UPLOAD_SIZE=10240

# Admin Panel
ADMIN_EMAIL=admin@routedns.io
ADMIN_PHONE=
SUPPORT_EMAIL=support@routedns.io

# Feature Flags
ENABLE_INVOICING=true
ENABLE_ANALYTICS=true
ENABLE_API_KEYS=true
ENABLE_SUPPORT_TICKETS=true
ENABLE_COUPONS=true
